{
  "sourceLanguage" : "en",
  "strings" : {
    "checkin.heavy.help" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "If you are soaking through a pad or tampon about every hour for several hours, or feel faint or short of breath, seek urgent medical care." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Если прокладка или тампон полностью промокают примерно каждый час в течение нескольких часов, либо появились слабость, обморочное состояние или одышка, срочно обратитесь за медицинской помощью." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "如果连续数小时大约每小时就浸透一片卫生巾或一枚卫生棉条，或出现头晕、晕厥感或呼吸急促，请尽快寻求紧急医疗帮助。" } } } },
    "checkin.heavy.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Know when to get help" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Когда нужна помощь" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "了解何时需要就医" } } } },
    "archive.error.fileSize" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The backup is larger than the 5 MB safety limit." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Размер резервной копии превышает безопасный лимит 5 МБ." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "备份文件超过 5 MB 安全上限。" } } } },
    "archive.error.grocery" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The backup contains an invalid grocery item." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "В резервной копии есть некорректный элемент списка покупок." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "备份中包含无效的购物清单物品。" } } } },
    "archive.error.records" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The backup contains too many records to import safely." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Резервная копия содержит слишком много записей для безопасного импорта." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "备份记录过多，无法安全导入。" } } } },
    "today.plan.hydrate" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Hydrate regularly" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Регулярно пейте воду" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "规律补充水分" } } } },
    "today.plan.hydrate.detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Keep water nearby and respond to thirst" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Держите воду рядом и ориентируйтесь на жажду" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "把水放在手边，按口渴情况饮用" } } } },
    "today.plan.move" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Choose comfortable movement" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Выберите комфортное движение" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "完成舒适的活动" } } } },
