    "checkin.pain.help" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "0 is no pain; 10 is the worst pain you can imagine." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "0 — боли нет; 10 — самая сильная боль, которую можно представить." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "0 表示无痛，10 表示能够想象的最剧烈疼痛。" } } } },
    "checkin.painLevel" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Pain level" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Уровень боли" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "疼痛程度" } } } },
    "common.couldNotSave" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Could not save" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Не удалось сохранить" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "无法保存" } } } },
    "periodEditor.overlapError" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This date range overlaps another recorded period. Edit the existing record instead." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Этот диапазон пересекается с другой записью. Измените существующую запись." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "这个日期范围与已有经期记录重叠，请编辑已有记录。" } } } },
    "profile.phaseAutomatic" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Automatic estimate" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Автоматический расчёт" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "自动估算" } } } },
    "profile.phaseOverride" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Phase" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Фаза" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "周期阶段" } } } },
    "archive.error.date" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The backup contains an invalid date." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Резервная копия содержит неверную дату." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "备份中包含无效日期。" } } } },
    "archive.error.duplicate" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The backup contains duplicate records." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Резервная копия содержит повторяющиеся записи." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "备份中包含重复记录。" } } } },
    "archive.error.log" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The backup contains an invalid daily check-in." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Резервная копия содержит неверную ежедневную запись." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "备份中包含无效的每日打卡。" } } } },
    "archive.error.settings" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The backup contains invalid cycle settings." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Резервная копия содержит неверные настройки цикла." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "备份中包含无效周期设置。" } } } },
    "archive.error.unreadable" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This backup file could not be read." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Не удалось прочитать файл резервной копии." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "无法读取这个备份文件。" } } } },
    "archive.error.version" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This backup version is not supported." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Эта версия резервной копии не поддерживается." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "暂不支持这个备份版本。" } } } },
    "profile.data.export" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Export backup" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Экспортировать копию" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "导出备份" } } } },
    "profile.data.help" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Backups contain sensitive cycle information. Store them somewhere private." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Копии содержат конфиденциальные данные о цикле. Храните их в безопасном месте." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "备份包含敏感周期信息，请保存在私密、安全的位置。" } } } },
    "profile.data.import" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Import backup" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Импортировать копию" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "导入备份" } } } },
    "profile.data.importSuccess" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Your LunaPlate data was restored." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Данные LunaPlate восстановлены." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "LunaPlate 数据已恢复。" } } } },
    "profile.data.messageTitle" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Data backup" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Резервная копия" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "数据备份" } } } },
    "profile.data.replace" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Replace and restore" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Заменить и восстановить" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "替换并恢复" } } } },
    "profile.data.replaceHelp" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "All cycle records, check-ins, settings, and grocery items on this device will be replaced." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Все записи цикла, отметки, настройки и покупки на устройстве будут заменены." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "本机现有的周期记录、每日打卡、设置和购物清单将被替换。" } } } },
    "profile.data.replaceTitle" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Replace current data?" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Заменить текущие данные?" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "替换当前数据？" } } } },
    "profile.data.section" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Backup and restore" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Резервное копирование" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "备份与恢复" } } } },
    "insights.average.format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Recent average: %d days" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Среднее за последнее время: %d дней" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "近期平均：%d 天" } } } },
    "insights.irregular" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Recent cycle lengths vary considerably. Estimates are shown as a range; talk with a clinician if this pattern is new or concerns you." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Длина последних циклов заметно различается. Прогноз показан диапазоном; обсудите это с врачом, если изменение новое или беспокоит вас." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "近期周期长度波动较大，预测将显示为范围；如果这是新变化或令你担心，建议咨询医疗专业人员。" } } } },
    "insights.openCalendar" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Open cycle calendar" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Открыть календарь цикла" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "打开周期日历" } } } },
    "insights.pattern.format" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "%@ has appeared most often during your %@." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "%@ чаще всего отмечалось в фазе: %@." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "%@ 最常出现在你的%@。" } } } },
    "insights.symptoms.empty" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Complete a few daily check-ins to see which symptoms occur most often." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Заполните несколько ежедневных отметок, чтобы увидеть частые симптомы." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "完成几次每日打卡后，这里会显示最常出现的症状。" } } } },
    "insights.symptoms.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Symptom patterns" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Закономерности симптомов" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "症状规律" } } } },
    "insights.trend.empty.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "More history needed" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Нужно больше данных" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "需要更多历史记录" } } } },
    "notification.checkin.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Take a quiet minute to record how your body feels today." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Уделите минуту и отметьте сегодняшнее самочувствие." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "花一分钟，安静记录今天的身体感受。" } } } },
    "notification.checkin.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Your LunaPlate check-in" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Ежедневная отметка LunaPlate" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "LunaPlate 每日打卡" } } } },
    "notification.periodSoon.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Your estimated period may begin in about two days. This date can shift." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "По прогнозу менструация может начаться примерно через два дня. Дата может измениться." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "预计经期可能在约两天后开始，实际日期可能变化。" } } } },
    "notification.periodSoon.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "A gentle cycle heads-up" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Напоминание о цикле" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "温和的周期提醒" } } } },
    "notification.periodToday.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Today is an estimated start date. Record what actually happens when you are ready." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Сегодня предполагаемая дата начала. Запишите фактические изменения, когда будете готовы." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "今天是预计开始日期；准备好后，请记录实际情况。" } } } },
    "notification.periodToday.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Estimated period date" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Предполагаемая дата менструации" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "预计经期日期" } } } },
    "profile.notifications.deniedBody" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Notifications are off. You can enable them later in iPhone Settings." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Уведомления выключены. Их можно включить позже в настройках iPhone." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "通知尚未开启，可以稍后在 iPhone 设置中允许。" } } } },
    "profile.notifications.deniedTitle" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Notifications not enabled" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Уведомления не включены" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "通知未开启" } } } },
    "profile.notifications.enable" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Cycle and check-in reminders" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Напоминания о цикле и отметках" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "周期与打卡提醒" } } } },
    "profile.notifications.help" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Period reminders are estimates. Notifications are scheduled on this device and update when the app opens." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Напоминания о менструации приблизительны и обновляются на устройстве при открытии приложения." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "经期提醒仅为估算，通知在本机安排，并会在打开 App 时更新。" } } } },
    "profile.notifications.section" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Reminders" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Напоминания" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "提醒" } } } },
    "profile.notifications.time" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Daily check-in time" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Время ежедневной отметки" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "每日打卡时间" } } } },
    "privacy.controls.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "You can export a readable backup, restore from a backup, or delete all local data from Profile." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "В профиле можно экспортировать копию, восстановить данные или удалить все локальные данные." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "你可以在个人设置中导出备份、从备份恢复或删除全部本机数据。" } } } },
    "privacy.controls.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Your controls" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Ваш контроль" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "你的控制权" } } } },
    "privacy.local.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Cycle dates, daily check-ins, notes, settings, and grocery items are stored in SwiftData on this device. LunaPlate does not currently create an account or cloud profile." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Даты цикла, ежедневные отметки, заметки, настройки и покупки хранятся в SwiftData на устройстве. Сейчас LunaPlate не создаёт аккаунт или облачный профиль." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "周期日期、每日打卡、备注、设置和购物清单通过 SwiftData 保存在本设备。LunaPlate 当前不创建账号或云端档案。" } } } },
    "privacy.local.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Stored on your device" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Хранение на устройстве" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "保存在你的设备" } } } },
    "privacy.medical.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Health information boundary" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Границы медицинской информации" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "健康信息边界" } } } },
    "privacy.network.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The active cycle phase, selected symptom identifiers, and food preferences are sent to the configured recommendation server to return meals and movement. The current Python service is designed not to persist them." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Активная фаза цикла, выбранные симптомы и пищевые предпочтения отправляются серверу рекомендаций для подбора питания и движения. Текущий Python-сервис не сохраняет их." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当前周期阶段、选择的症状标识和饮食偏好会发送至配置的推荐服务器，以返回餐食和运动建议；当前 Python 服务按设计不会持久保存这些信息。" } } } },
    "privacy.network.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Recommendation requests" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Запросы рекомендаций" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "推荐请求" } } } },
    "privacy.notUsed.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "LunaPlate does not use health information for advertising or tracking and currently includes no advertising or analytics SDK." } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "LunaPlate не использует данные о здоровье для рекламы или отслеживания и не содержит рекламных или аналитических SDK." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "LunaPlate 不将健康信息用于广告或追踪，目前也未集成广告或分析 SDK。" } } } },
    "privacy.notUsed.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "No advertising or tracking" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Без рекламы и отслеживания" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "不用于广告或追踪" } } } },
    "privacy.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Privacy" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Конфиденциальность" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "隐私" } } } },
    "profile.privacy.details" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "How LunaPlate handles data" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Как LunaPlate обрабатывает данные" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "LunaPlate 如何处理数据" } } } },
    "profile.data.deleteAll" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Delete all local data" } }, "ru" : { "stringUnit" : { "state" : "translated", "value" : "Удалить все локальные данные" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "删除全部本机数据" } } } },
